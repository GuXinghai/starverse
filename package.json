{
  "name": "starverse-client",
  "productName": "Starverse",
  "version": "0.0.2",
  "description": "基于 Electron + Vue 3 的新一代跨平台 AI 对话桌面应用",
  "author": "GuXinghai",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "npm run gen:build-id && npm run build:worker && chcp 65001 >nul 2>&1 & cross-env FORCE_COLOR=1 vite --host",
    "build": "npm run clean:dist && npm run gen:build-id && npm run build:worker && vue-tsc && vite build && electron-builder install-app-deps && electron-builder",
    "preview": "vite preview",
    "electron:dev": "chcp 65001 >nul 2>&1 & npm run rebuild:electron && cross-env FORCE_COLOR=1 concurrently --kill-others \"npm run watch:worker\" \"npm run dev\"",
    "electron": "npm run electron:dev",
    "electron:build": "npm run build",
    "dev:netlog": "node ./scripts/run-electron-with-netlog.mjs",
    "dev:netlog:sensitive": "cross-env SV_NETLOG_CAPTURE_MODE=IncludeSensitive SV_NETLOG_ALLOW_SENSITIVE=1 node ./scripts/run-electron-with-netlog.mjs",
    "dev:clean": "chcp 65001 >nul 2>&1 & taskkill /F /IM electron.exe 2>nul & npm run dev",
    "dev:quiet": "npm run gen:build-id && chcp 65001 >nul 2>&1 & cross-env FORCE_COLOR=1 NODE_ENV=development vite --host --logLevel silent",
    "clean:dist": "node ./scripts/clean-dist.cjs",
    "gen:build-id": "node ./scripts/gen-build-id.cjs",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "npx electron-rebuild -f -w better-sqlite3",
    "rebuild": "npm run rebuild:electron",
    "build:worker": "node ./scripts/build-db-worker.cjs",
    "watch:worker": "node ./scripts/build-db-worker.cjs --watch",
    "db:reset": "node ./scripts/db-reset.cjs",
    "db:verify": "npm run rebuild:node && node ./scripts/db-verify.cjs",
    "test": "npm run rebuild:node && vitest --run",
    "test:model-catalog:smoke": "vitest --run src/shared/modelCatalog/openRouterCatalogClient.test.ts src/shared/modelCatalog/modelTagger.test.ts src/next/modelCatalog/catalogQueryService.test.ts src/next/modelCatalog/catalogSyncJob.test.ts infra/db/repo/modelCatalogRepo.test.ts tests/integration/model-catalog-sync-query-smoke.test.ts tests/integration/model-catalog-stage4-smoke.test.ts",
    "test:model-picker:smoke": "vitest --run tests/integration/model-catalog-sync-query-smoke.test.ts tests/integration/model-catalog-stage4-smoke.test.ts src/next/modelCatalog/catalogQueryService.test.ts src/next/modelCatalog/modelEndpointDetailService.test.ts src/ui-app/components/EndpointDetailPanel.test.ts src/ui-app/components/ModelPickerDialog.test.ts src/ui-app/components/ChatAppComposer.modelPicker.test.ts src/ui-app/AppChatApp.send.test.ts src/next/modelPrefs/modelPrefsService.test.ts infra/db/repo/modelPreferencesRepo.test.ts",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .js,.cjs,.mjs,.ts,.tsx,.vue",
    "lint:changed": "node ./scripts/lint-changed.cjs",
    "verify:ssot": "npm run test && node scripts/gates/tc17-ui-guardrails.mjs && node scripts/gates/tc18-ui-isolation.mjs && node scripts/gates/tc12.mjs --skip-tests && node scripts/gates/tc16-ssot-reasoning-visibility.mjs && node scripts/gates/tc15-git-clean.mjs",
    "verify:live": "node scripts/gates/tc14-ui-live-smoke.mjs",
    "gate:tc13": "node scripts/gates/tc13-ui-isolation.mjs",
    "gate:tc14": "node scripts/gates/tc14-ui-live-smoke.mjs",
    "gate:tc15": "node scripts/gates/tc15-git-clean.mjs",
    "gate:tc17": "node scripts/gates/tc17-ui-guardrails.mjs",
    "gate:tc18": "node scripts/gates/tc18-ui-isolation.mjs",
    "gate:tc20": "node scripts/gates/tc20-katex-css-artifact.mjs",
    "verify:artifact-katex-css": "npx vite build && npm run gate:tc20",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "postinstall": "npm run rebuild:node"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/uuid": "^10.0.0",
    "@vueuse/core": "^14.0.0",
    "better-sqlite3": "^12.4.1",
    "dompurify": "^3.3.0",
    "electron-store": "^11.0.2",
    "katex": "^0.16.25",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.3",
    "shiki": "^3.22.0",
    "undici": "^7.19.2",
    "uuid": "^13.0.0",
    "vue": "^3.4.21",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/vue3": "^8.6.14",
    "@storybook/vue3-vite": "^8.6.14",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/browser": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.6.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^4.0.1",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.1",
    "jsdom": "^25.0.1",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "storybook": "^8.6.14",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^2.1.9",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.0.26",
    "wait-on": "^9.0.1"
  },
  "main": "dist-electron/main.js"
}
